# Configuration for docker-compose.registry.yml. Copy to `.env.registry` (gitignored) and
# run: docker compose --env-file .env.registry -f docker-compose.registry.yml up
# Full server config reference: docs/CONFIGURATION.md. No AWS/deploy config here.

# Required: password for the bundled Postgres. Set a strong value and keep it
# stable — the Postgres data volume is initialized with it on first run.
# Use only URL-safe characters (e.g. hex/alphanumeric): it is embedded verbatim
# in DATABASE_URL, so `@ : / # ?` would break connection-string parsing.
POSTGRES_PASSWORD=change-me

# Optional: published image version to run (default: latest).
# GUARDIAN_VERSION=v1.2.3

# --- Optional server runtime config (uncomment as needed) ---

# Miden network the server targets (server default: MidenDevnet).
# GUARDIAN_NETWORK_TYPE=MidenTestnet

# Comma-separated origins allowed by credentialed CORS.
# GUARDIAN_CORS_ALLOWED_ORIGINS=https://accounts.openzeppelin.com

# Dashboard operator public keys (Falcon), as a JSON file mounted into the container.
# GUARDIAN_OPERATOR_PUBLIC_KEYS_FILE=/var/guardian/operators.json

# Rate limiting (optional tuning).
# GUARDIAN_RATE_LIMIT_ENABLED=true
# GUARDIAN_RATE_PER_MIN=600
# GUARDIAN_RATE_BURST_PER_SEC=20
