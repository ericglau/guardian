        ],
        "summary": "Add an approval signature to an EVM proposal (requires an EVM session).",
        "operationId": "approve_evm_proposal",
        "parameters": [
          {
            "name": "proposal_id",
            "in": "path",
            "description": "Proposal identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveProposalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Approval recorded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EvmProposal"
                }
              }
            }
          },
          "400": {
